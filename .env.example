# GEMINI_API_KEY: Optional. Required only for Gemini-powered admin generation.
GEMINI_API_KEY="your_gemini_api_key"

# Public site URL used for links, metadata, and auth callbacks.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase project values.
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Secret required for hitting the on-demand revalidation endpoint
REVALIDATION_SECRET="my_random_secret_token"
